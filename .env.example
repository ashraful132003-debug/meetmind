# =============================================================================
# MeetMind — environment configuration
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed or shipped to the frontend.
# =============================================================================

# --- Core ---------------------------------------------------------------------
APP_ENV=development
APP_NAME=MeetMind
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# --- Secrets ------------------------------------------------------------------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# Each must be unique. Rotating JWT_SECRET logs everyone out (by design).
JWT_SECRET=change-me-to-a-long-random-string
# Fernet key for encrypting transcripts at rest.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-fernet-key
# Signs time-limited audio download URLs.
MEDIA_SIGNING_SECRET=change-me-to-another-long-random-string

# --- Tokens -------------------------------------------------------------------
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14

# --- Database -----------------------------------------------------------------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=meetmind
POSTGRES_USER=meetmind
POSTGRES_PASSWORD=change-me-local-db-password

# --- LLM ----------------------------------------------------------------------
# provider: ollama (free, local, default) | anthropic | openai
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
# all-minilm is 46MB and plenty for searching one meeting's transcript.
# Swap to nomic-embed-text (274MB) for better recall on long meetings.
OLLAMA_EMBED_MODEL=all-minilm
# Only used when LLM_PROVIDER is switched away from ollama. Leave blank otherwise.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Transcription ------------------------------------------------------------
# tiny | base | small | medium  (small = good accuracy/speed on RTX 3050)
WHISPER_MODEL=small
# auto | cuda | cpu
# CUDA also needs NVIDIA's runtime DLLs: pip install nvidia-cublas-cu12 nvidia-cudnn-cu12
# Without them the code detects the GPU is unusable and falls back to CPU.
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8

# --- Speaker recognition (diarization) ---------------------------------------
# WeSpeaker ResNet34 ONNX, 25MB. Get it with: .\scripts\get_speaker_model.ps1
# Optional - without it, diarization falls back to hand-built features.
# Measured on the seed meetings: 94.0% with this model, 79.5% without.
SPEAKER_MODEL_PATH=./storage/models/wespeaker.onnx

# --- Email --------------------------------------------------------------------
# transport: local (captures to disk + in-app inbox, no credentials) | smtp
EMAIL_TRANSPORT=local
EMAIL_FROM=MeetMind <no-reply@meetmind.local>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true

# --- Storage ------------------------------------------------------------------
MEDIA_DIR=./storage/media
MAX_UPLOAD_MB=200

# --- Rate limiting ------------------------------------------------------------
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_UPLOAD_PER_HOUR=30
